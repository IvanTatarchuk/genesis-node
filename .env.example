# ── Supabase ──────────────────────────────────────────────────────
# Create a project, run supabase/schema.sql against it, then fill these in.
# SERVICE_ROLE_KEY bypasses RLS — server-side only, never expose to the client.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ── Challenge moderation ─────────────────────────────────────────
# Shared secret for POST /api/challenges/[slug]/moderate (approve/reject a
# player-authored challenge submission). Generate with: openssl rand -hex 32
ADMIN_SECRET=<random-hex-secret>
