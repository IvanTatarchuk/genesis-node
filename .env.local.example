# Copy to .env.local and fill in.

# Supabase project (Settings -> API). Run supabase/schema.sql against this
# project before starting the app, or /leaderboard and run-recording will
# fail with a clear "not configured" error rather than crash.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# Players paste their own Anthropic API key into the UI per-run; nothing
# server-side is needed for that. This var is optional, only useful if you
# want a fallback/demo key for local development.
# ANTHROPIC_API_KEY=
