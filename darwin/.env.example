SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5
GENESIS_API_URL=https://matadora.business
DARWIN_USER_ID=             # optional; set automatically on first run
DARWIN_PASSWORD=            # required when creating Darwin user (do not derive from SUPABASE_KEY)
OWNER_USER_ID=              # optional; get notifications when agents are published
AGENTS_PER_DAY=10
PORT=8080
CRON_SECRET=                # required in prod for POST /run (e.g. same as CRON_SECRET on Vercel)
MAX_AGENTS_PER_CATEGORY_PER_DAY=3
LLM_RETRIES=3
# Optional: Ollama as primary or fallback
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:0.5b
