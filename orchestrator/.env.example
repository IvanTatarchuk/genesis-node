# Option C: Anthropic Claude (paid API)
# ANTHROPIC_API_KEY=sk-ant-...
# ────────────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_TASKS=3
TASK_TIMEOUT_SECONDS=300
POLL_INTERVAL_SECONDS=5
MAX_STEPS=15
