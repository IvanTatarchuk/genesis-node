# Supabase (service role key â€” full access)
SUPABASE_URL=https://qmvorahyrzrfvigxdwrq.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# LLM: Ollama (free) or Anthropic Claude
# When OLLAMA_URL is set, uses local Ollama â€” no API costs
OLLAMA_URL=
