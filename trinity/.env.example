# Platform
GENESIS_API_URL=https://matadora.business

# Owner's Supabase user ID (for system alerts)
OWNER_USER_ID=your_supabase_user_id_here

# GitHub â€” for autonomous code writing and deployment
# Create at: https://github.com/settings/tokens (repo + workflow scopes)
GITHUB_TOKEN=your_github_pat_here

# Vercel â€” for autonomous deployment management
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Railway â€” for service management (already used)
RAILWAY_TOKEN=your_railway_token_here

# Server port
PORT=8090
